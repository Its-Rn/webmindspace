    "@testing-library/react": "^16.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "vitest": "^3.1.3",
    "jest": "^30.0.0",
