    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "morgan": "^1.11.0",
    "ms": "^2.1.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pusher": "^5.3.4",
    "zod": "^4.4.3",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "framer-motion": "^12.42.2",
