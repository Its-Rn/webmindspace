{
  "name": "personal-productivity-platform",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "A production-ready full-stack personal productivity platform scaffold.",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server run start",
    "seed": "npm --prefix server run seed",
    "setup": "npm install"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "serverless-http": "^4.0.0",
    "bcrypt": "^6.0.0",
