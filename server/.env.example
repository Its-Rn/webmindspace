# ─── Environment ───
NODE_ENV=development

# ─── Server ───
PORT=5000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# ─── Database ───
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/productivity-platform

# ─── JWT ───
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary (optional — for image uploads) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Pusher (required — for real-time chat) ───
# Create a free account at https://dashboard.pusher.com
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# ─── SMTP (optional — for contact form emails) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
CONTACT_EMAIL=
